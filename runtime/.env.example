APP_ENV=local

# Which LLM backend the runtime uses: groq | anthropic
AI_PROVIDER=groq

# Required when AI_PROVIDER=groq. Model is env-driven — pick a currently
# available tool-capable model from https://console.groq.com/docs/models
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai

# Required only when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

LARAVEL_INTERNAL_URL=http://127.0.0.1:8000
AI_RUNTIME_SHARED_SECRET=change-me-local
CORS_ALLOWED_ORIGINS=
REQUEST_TIMEOUT_SECONDS=60
